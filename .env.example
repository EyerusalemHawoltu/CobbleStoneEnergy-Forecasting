# Copy to .env and fill in your credentials — never commit .env

# Groq API key (FREE — register at console.groq.com, no credit card required)
# Powers the AI agent (Llama 3.3 70B) and daily commentary
GROQ_API_KEY=your_groq_api_key_here

# ENTSO-E Transparency Platform API key (register at transparency.entsoe.eu)
# NOT required if local CSV files are present in data/raw/:
#   energyprice2024.csv, energyprice2025.csv, energyprice2026.csv
#   load2024.csv, load2025.csv, load2026.csv
# Only needed if you want to re-download data from the API.
# ENTSOE_API_KEY=your_entsoe_api_key_here
