# ── AI / LLM ─────────────────────────────────────────────────────────────────
# Groq free tier — register at https://console.groq.com
# Powers AI chat agent, automated commentary, and LLM-driven QA rules.
# Without this key the pipeline runs fine but LLM features return a fallback message.
GROQ_API_KEY=your_groq_api_key_here

# ── ENTSO-E API (optional) ────────────────────────────────────────────────────
# Not required — local CSV files in data/raw/ are already present.
# Only set this if you want to re-download fresh data from the ENTSO-E API.
# ENTSOE_API_KEY=your_entsoe_api_key_here

# ── CORS (production) ─────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Set this in your Railway environment variables to your Vercel deployment URL.
# Example: CORS_ORIGINS=https://your-app.vercel.app,http://localhost:5173
# Leave unset in local dev — defaults to allow all origins.
# CORS_ORIGINS=https://your-app.vercel.app
